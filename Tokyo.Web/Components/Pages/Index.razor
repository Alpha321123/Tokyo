@page "/"

<PageTitle>東京旅行規劃器 | Tokyo Trip Planner 東京旅行プランナー</PageTitle>

<div class="modern-planner">
  <!-- Hero Section -->
  <header class="hero-section">
    <div class="hero-bg"></div>
    <div class="hero-content">
      <h1 class="hero-title">東京 9 天深度遊</h1>
      <p class="hero-subtitle">完整行程規劃：景點、美食、交通、票券一網打盡</p>
      <div class="trip-meta">
        <span class="meta-item">📅 2024/5/29 - 6/6</span>
        <span class="meta-item">✈️ JQ009/010 (BNE-NRT)</span>
        <span class="meta-item">🏨 上野住宿</span>
      </div>
      <div class="hero-actions">
        <button class="btn-primary print-btn" onclick="window.print()">列印行程</button>
        <button class="btn-secondary dark-toggle" id="darkToggle">🌙 夜間模式</button>
      </div>
    </div>
  </header>

  <!-- Quick Stats -->
  <section class="stats-grid">
    <div class="stat-card">
      <div class="stat-icon">🎯</div>
      <h3>主要景點</h3>
      <p>東京塔、迪士尼海洋、獨角獸鋼彈、淺草寺</p>
    </div>
    <div class="stat-card">
      <div class="stat-icon">🍣</div>
      <h3>必吃美食</h3>
      <p>豐洲市場壽司、宇奈とと、上野阿美橫、海鮮丼</p>
    </div>
    <div class="stat-card">
      <div class="stat-icon">🚆</div>
      <h3>交通卡</h3>
      <p>Suica/PASMO + 百合海鷗號一日券 ¥800</p>
    </div>
    <div class="stat-card">
      <div class="stat-icon">💰</div>
      <h3>重點票券</h3>
      <p>DisneySea ¥10,000、森JP Tower ¥2,000</p>
    </div>
  </section>

  <!-- Table of Contents -->
  <nav class="toc-section">
    <h2>📋 快速導航</h2>
    <div class="toc-list">
      <a href="#day1" class="toc-link">Day 1: 抵達上野</a>
      <a href="#day2" class="toc-link">Day 2: 麻布台東京塔</a>
      <a href="#day3" class="toc-link">Day 3: 自由日</a>
      <a href="#day4" class="toc-link">Day 4: DisneySea</a>
      <a href="#day5" class="toc-link">Day 5: 淺草秋葉原</a>
      <a href="#day6" class="toc-link">Day 6: 豐洲台場</a>
      <a href="#day7" class="toc-link">Day 7: 吉祥寺澀谷</a>
      <a href="#day8" class="toc-link">Day 8: 豪德寺銀座</a>
      <a href="#day9" class="toc-link">Day 9: 回程</a>
    </div>
  </nav>

  <!-- Daily Plans -->
  <main class="daily-plans">
    <section class="day-card" id="day1">
      <div class="day-header">
        <h2>第1天：抵達 & 上野夜遊</h2>
        <span>5/29 (三) | Arrival & Ueno / 成田→上野</span>
      </div>
      <div class="timeline">
        <div class="timeline-item">
          <div class="time">09:30</div>
          <div class="content">
            <h4>✈️ 出發布里斯本</h4>
            <p>BNE → NRT | JQ009 | 飛行時間約9小時</p>
          </div>
        </div>
        <div class="timeline-item">
          <div class="time">17:40</div>
          <div class="content">
            <h4>🛬 成田機場T3入境</h4>
            <p>辦理Suica卡、購買SIM卡</p>
          </div>
        </div>
        <div class="timeline-item highlight">
          <div class="time">18:30-19:30</div>
          <div class="content">
            <h4>🚆 Skyliner至上野</h4>
            <p>成田特快 | 約60分 | ¥2,570</p>
          </div>
        </div>
        <div class="timeline-item highlight">
          <div class="time">20:00</div>
          <div class="content">
            <h4>🍣 上野晚餐</h4>
            <p><strong>名代宇奈とと</strong>鰻魚飯 | <strong>廻転寿司まぐろ問屋</strong>迴轉壽司</p>
          </div>
        </div>
      </div>
    </section>

    <section class="day-card highlight-day" id="day2">
      <div class="day-header">
        <h2>第2天：麻布台 & 東京塔</h2>
        <span>5/30 (四) | Azabudai Hills & Tokyo Tower / 麻布台之丘・東京タワー</span>
      </div>
      <div class="timeline">
        <div class="timeline-item">
          <div class="time">09:00</div>
          <div class="content">
            <h4>🎪 Tokyo City Flea Market</h4>
            <p>青山公園早市 | 免費入場</p>
          </div>
        </div>
        <div class="timeline-item">
          <div class="time">11:00</div>
          <div class="content">
            <h4>🏢 麻布台之丘 / Azabudai Hills</h4>
            <p>日本第一高樓 | TeamLab Borderless</p>
          </div>
        </div>
        <div class="timeline-item highlight">
          <div class="time">12:00</div>
          <div class="content">
            <h4>🍽️ Sky Lobby午餐</h4>
            <p>Dining 33或Sky Room Cafe (消費入場)</p>
          </div>
        </div>
        <div class="timeline-item">
          <div class="time">14:30</div>
          <div class="content">
            <h4>🌆 森JP Tower展望台</h4>
            <p>票價¥2,000 | 360°東京全景</p>
          </div>
        </div>
        <div class="timeline-item">
          <div class="time">16:00</div>
          <div class="content">
            <h4>🗼 東京塔主展望台</h4>
            <p>票價¥1,200 | 落日時分最佳</p>
          </div>
        </div>
        <div class="timeline-item highlight">
          <div class="time">17:30</div>
          <div class="content">
            <h4>🧁 下午茶甜點</h4>
            <p>HARBS芝公園店 | 千疋屋總本店草莓大福</p>
          </div>
        </div>
        <div class="timeline-item">
          <div class="time">19:30</div>
          <div class="content">
            <h4>🍲 晚餐：五代目野田岩</h4>
            <p>芝浦名店鰻魚飯 | 約¥5,000</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Continue similarly for other days... (abbreviated for brevity) -->
    <section class="day-card highlight-day" id="day4">
      <div class="day-header">
        <h2>第4天：東京迪士尼海洋</h2>
        <span>6/1 (六) | DisneySea全天 | 東京ディズニーシー</span>
      </div>
      <div class="timeline">
        <div class="timeline-item">
          <div class="time">08:00</div>
          <div class="content">
            <h4>🚆 出發舞濱站</h4>
            <p>JR京葉線約30分</p>
          </div>
        </div>
        <div class="timeline-item highlight">
          <div class="time">09:00-22:00</div>
          <div class="content">
            <h4>🎢 DisneySea遊樂</h4>
            <p>1日票¥10,900 | 必玩：印地瓊斯、玩具總動員</p>
          </div>
        </div>
      </div>
    </section>

    <!-- More days... -->
  </main>

  <!-- Tickets Summary -->
  <section class="tickets-section">
    <h2>🎫 票券購置清單</h2>
    <div class="tickets-grid">
      <div class="ticket-card">
        <h3>Suica交通卡</h3>
        <p>機場購買 | ¥2,000 (含¥500押金)</p>
      </div>
      <div class="ticket-card highlight">
        <h3>DisneySea 1日票</h3>
        <p>¥10,900 | 官網/APP提前購</p>
      </div>
      <!-- etc. -->
    </div>
  </section>

  <!-- Tips & Packing -->
  <section class="tips-section">
    <h2>💡 旅行提示 & 打包清單</h2>
    <div class="tips-grid">
      <div>📱 Google Maps離線地圖</div>
      <div>💳 國際信用卡+現金</div>
      <div>🔌 轉換插頭Type A</div>
    </div>
  </section>
</div>

<script>
  // Dark mode toggle
  const toggle = document.getElementById('darkToggle');
  toggle.addEventListener('click', () => {
    document.body.classList.toggle('dark-mode');
    toggle.textContent = document.body.classList.contains('dark-mode') ? '☀️ 日間模式' : '🌙 夜間模式';
  });
</script>

<style>
/* Inline preview styles - full CSS in app.css */
.modern-planner { max-width: 1200px; margin: 0 auto; padding: 2rem; }
.hero-section { position: relative; height: 60vh; background: linear-gradient(135deg, #ff6b6b, #4ecdc4); color: white; }
</style>
